# ─────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in your keys
# ─────────────────────────────────────────────────────────────

# Groq — free LLM API: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# LangSmith — free agent tracing: https://smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=DHL-Stakeholder-RAG

# Tavily — free web search: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
